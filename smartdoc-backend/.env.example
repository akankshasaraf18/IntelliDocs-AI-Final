# IntelliDocs AI Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/intellidocs-ai
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/intellidocs-ai?retryWrites=true&w=majority

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
# For production:
# CORS_ORIGIN=https://your-frontend-domain.com

# Google Generative AI Configuration
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# OpenAI Configuration (optional, for alternative AI features)
OPENAI_API_KEY=your-openai-api-key

# JWT Configuration (for authentication)
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRE=7d

# Cloudinary Configuration (optional, for file storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# File Upload Configuration
MAX_FILE_SIZE=50mb
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug, trace
