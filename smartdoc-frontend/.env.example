# IntelliDocs AI Frontend Environment Variables

# Auth0 Configuration
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_CALLBACK_URL=http://localhost:5173

# Backend API Configuration
# For local development:
VITE_API_BASE_URL=http://localhost:5000

# For production (e.g., Render or other hosting):
# VITE_API_BASE_URL=https://your-backend-domain.onrender.com

# Google Generative AI Configuration (if using client-side)
VITE_GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Optional: Application Configuration
VITE_APP_NAME=IntelliDocs AI
VITE_APP_VERSION=1.0.0
